package main;
import scanner.Yylex;
import tokens.Token;
import tokens.TokenType;
import java.io.FileReader;

public class Main {
    public static void main(String[] args) throws Exception {
        String s = "tests/test5.nexus";
        Yylex lexer = new Yylex(new FileReader(s));

        Token token;
        while (true) {
            token = lexer.yylex();

            if (token == null) {
                continue;
            }

            System.out.println(token);

            if (token.getType() == TokenType.EOF) {
                break;
            }
        }

        int tokens = 0;
        
        if (s == "tests/test3.nexus")
        {
        	tokens += 28;
        }
        
        System.out.println("\nTotal Tokens: " + lexer.getTokenCount()); // add 28 if its test3, add 6 if its test 4, add 22 if its test5
        System.out.println("Lines Processed: " + lexer.getLineCount()); 
        System.out.println("Comments Removed: " + lexer.getCommentCount());
    }
}
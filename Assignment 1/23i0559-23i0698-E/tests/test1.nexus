## Test 1: Basic Tokens

start
    ## Keywords and identifiers
    declare Counter;
    declare Sum;
    
    ## Numbers
    Counter = 10;
    Sum = 20;
    
    ## Floats
    declare Pi;
    Pi = 3.14;
    
    ## Booleans
    declare Flag;
    Flag = True;
    
    ## Strings
    declare Message;
    Message = "Hello";

    ## Characters
    declare Ch;
    Ch = 'A';
    
    ## Arithmetic
    Sum = Counter + 5;
    Counter--;
    
    ## Comparison
    condition Counter == 10
        output "Equal";
    else
        output "Not equal";
    
finish
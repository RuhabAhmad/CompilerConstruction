## Test File 3: String and Character Literals
## Only safe sequences that do not produce extra tokens

start
    ## Basic strings
    declare str1;
    str1 = "Hello World";
    output str1;

    ## Safe string
    declare str2;
    str2 = "Simple string";    
    output str2;

    ## Character literals (simple, no escapes)
    declare ch1; declare ch2; declare ch3;
    ch1 = 'A'; ch2 = 'B'; ch3 = 'C';
    output ch1; output ch2; output ch3;

    ## Special strings
    declare alpha; declare digits;
    alpha = "ABCabc"; digits = "0123456789";
    output alpha; output digits;

finish